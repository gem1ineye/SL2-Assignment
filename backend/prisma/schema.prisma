generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  trainer
  institution
  programme_manager
  monitoring_officer
}

enum AttendanceStatus {
  present
  absent
  late
}

model User {
  id          String   @id @default(uuid())
  clerkUserId String   @unique @map("clerk_user_id")
  name        String
  email       String   @unique
  role        UserRole
  institutionId String? @map("institution_id")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  institution     Institution?   @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  trainerBatches  BatchTrainer[]
  studentBatches  BatchStudent[]
  sessions        Session[]
  attendances     Attendance[]
  createdInvites  BatchInvite[]

  @@index([clerkUserId])
  @@index([role])
  @@index([institutionId])
  @@map("users")
}

model Institution {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  users   User[]
  batches Batch[]

  @@map("institutions")
}

model Batch {
  id            String   @id @default(uuid())
  name          String
  institutionId String   @map("institution_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  institution Institution    @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  trainers    BatchTrainer[]
  students    BatchStudent[]
  sessions    Session[]
  invites     BatchInvite[]

  @@index([institutionId])
  @@map("batches")
}

model BatchTrainer {
  id         String   @id @default(uuid())
  batchId    String   @map("batch_id")
  trainerId  String   @map("trainer_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  // Relations
  batch   Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  trainer User  @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([batchId, trainerId])
  @@map("batch_trainers")
}

model BatchStudent {
  id        String   @id @default(uuid())
  batchId   String   @map("batch_id")
  studentId String   @map("student_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  // Relations
  batch   Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([batchId, studentId])
  @@map("batch_students")
}

model Session {
  id        String   @id @default(uuid())
  batchId   String   @map("batch_id")
  trainerId String   @map("trainer_id")
  title     String
  date      DateTime @db.Date
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  batch      Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  trainer    User         @relation(fields: [trainerId], references: [id], onDelete: SetNull)
  attendance Attendance[]

  @@index([batchId])
  @@index([trainerId])
  @@index([date])
  @@map("sessions")
}

model Attendance {
  id        String           @id @default(uuid())
  sessionId String           @map("session_id")
  studentId String           @map("student_id")
  status    AttendanceStatus
  markedAt  DateTime         @default(now()) @map("marked_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  // Relations
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@map("attendance")
}

model BatchInvite {
  id         String   @id @default(uuid())
  batchId    String   @map("batch_id")
  inviteCode String   @unique @map("invite_code")
  createdBy  String   @map("created_by")
  isActive   Boolean  @default(true) @map("is_active")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  batch   Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  creator User  @relation(fields: [createdBy], references: [id])

  @@index([inviteCode])
  @@map("batch_invites")
}
